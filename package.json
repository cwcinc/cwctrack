{
  "name": "cwctrack",
  "version": "1.3.1",
  "main": "electron/main.js",
  "build": {
    "appId": "com.cwcinc.cwctrack",
    "productName": "CWCTrack",
    "files": [
      "package.json",
      "admin.bundle.js",
      "app.bundle.js",
      "editor.bundle.js",
      "error_screen.bundle.js",
      "garage.bundle.js",
      "haptics.bundle.js",
      "main.bundle.js",
      "simulation_worker.bundle.js",
      "SQLite.bundle.js",
      "verifier.bundle.js",
      "forced_square.json",
      "forced_square.ttf",
      "forced_square.woff",
      "forced_square.woff2",
      "favicon.ico",
      "index.html",
      "style.css",
      "polytrack_physics.wasm",
      "mods/**/*",
      "models/**/*",
      "images/**/*",
      "lib/**/*",
      "audio/**/*",
      "electron/**/*",
      "tracks/**/*"
    ],
    "win": {
      "icon": "build/icons/win/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CWCTrack",
      "runAfterFinish": true,
      "installerIcon": "build/icons/win/icon.ico",
      "uninstallerIcon": "build/icons/win/icon.ico",
      "installerHeaderIcon": "build/icons/win/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Game",
      "icon": "build/icons/png"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.games",
      "icon": "build/icons/mac/icon.icns"
    }
  },
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@xhayper/discord-rpc": "^1.3.4"
  }
}
